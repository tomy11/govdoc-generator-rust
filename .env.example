# LLM backend selection.
#   fake          -> deterministic in-process stub (default; used by tests)
#   typhoon-local -> local OpenAI-compatible server (mlx_lm.server + Typhoon MLX)
#   typhoon-cloud -> hosted Typhoon API (https://api.opentyphoon.ai/v1), needs key
LLM_BACKEND=fake

# Typhoon provider settings (used when LLM_BACKEND=typhoon-local|typhoon-cloud).
# LLM_BASE_URL/LLM_MODEL override the per-backend defaults below; leave unset to
# use them. LLM_BASE_URL must include the /v1 version prefix.
#   typhoon-local default base_url: http://127.0.0.1:8080/v1
#   typhoon-local default model:    typhoon-ai/typhoon2.5-qwen3-4b
#     (must match the id reported by mlx_lm.server at /v1/models)
#   typhoon-cloud default base_url: https://api.opentyphoon.ai/v1
#   typhoon-cloud default model:    typhoon-v2.5-30b-a3b-instruct
LLM_BASE_URL=
LLM_MODEL=
LLM_TEMPERATURE=0.2
# Optional nucleus sampling cutoff (sent only when set), e.g. 0.6 for the cloud.
LLM_TOP_P=
# Required for typhoon-cloud. Get a key at https://opentyphoon.ai.
LLM_API_KEY=

# Local model weights + sidecar server (see scripts/download_model.sh, serve_llm.sh).
LLM_MODEL_PATH=models/typhoon2.5-qwen3-4b-mlx
LLM_SERVER_HOST=127.0.0.1
LLM_SERVER_PORT=8080
# Set to 1 to have the API auto-start scripts/serve_llm.sh and wait for it.
LLM_AUTO_SERVE=0
LLM_SERVE_TIMEOUT_SECS=180

# Embedding backend for semantic retrieval.
#   fake   -> zero vectors; retrieval falls back to recency-based lookup (default)
#   remote -> OpenAI-compatible /v1/embeddings (also: typhoon, openai, cloud)
EMBEDDING_BACKEND=fake
# Used when EMBEDDING_BACKEND=remote. EMBEDDING_BASE_URL falls back to
# LLM_BASE_URL, and the API key falls back to LLM_API_KEY (local server ignores it).
#
# Local sidecar (scripts/serve_embeddings.sh, good for Thai, no key needed):
#   EMBEDDING_BACKEND=remote
#   EMBEDDING_BASE_URL=http://127.0.0.1:8090/v1
#   EMBEDDING_MODEL=BAAI/bge-m3
#   EMBEDDING_DIM=1024
# Note: Typhoon has no /v1/embeddings endpoint; use the local sidecar or another
# OpenAI-compatible provider (e.g. OpenAI text-embedding-3-small).

EMBEDDING_BACKEND=remote
EMBEDDING_BASE_URL=http://127.0.0.1:8090/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# Document OCR for ingestion (POST /ingest/ocr). Cloud-only; uses LLM_API_KEY.
OCR_BASE_URL=https://api.opentyphoon.ai/v1
OCR_MODEL=typhoon-ocr

MAX_LOOP_CAP=3
ENABLE_CRITIC=true

# Local-first storage paths.
SQLITE_PATH=app-data/govdoc.sqlite3
# Persistent vector index (derived from SQLite; rebuilt from it if missing).
HNSW_INDEX_PATH=app-data/hnsw.index

# Local API and rendering sidecar.
GOVDOC_API_ADDR=127.0.0.1:8000
GOVDOC_RENDERER_CMD=python3 scripts/render_docx_sidecar.py

# Optional path to the original Python project for docx rendering parity.
# Leave empty if the sidecar should only use explicit template paths.
GOVDOC_PYTHON_SOURCE=../govdoc-generator
