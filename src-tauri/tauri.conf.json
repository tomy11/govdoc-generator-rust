{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GovDoc Generator",
  "version": "0.1.0",
  "identifier": "com.govdoc.generator",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GovDoc Generator",
        "width": 1040,
        "height": 780,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/govdoc-api"]
  }
}
